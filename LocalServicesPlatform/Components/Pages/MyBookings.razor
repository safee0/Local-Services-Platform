@page "/my-bookings"
@rendermode InteractiveServer
@using LocalServicesPlatform.Models
@using LocalServicesPlatform.Services
@inject PlatformService DataService
@inject UserSession Session
@inject NavigationManager Nav

<div class="container mt-4">
    @if (!Session.IsLoggedIn || Session.Role != "Customer")
    {
        <div class="alert alert-danger shadow-sm rounded-3">
            <h4><i class="bi bi-shield-lock-fill me-2"></i>Access Denied</h4>
            <p>You must be signed in as a Customer to access this portal.</p>
            <a href="login" class="btn btn-primary btn-sm rounded-pill px-3">Go to Login</a>
        </div>
    }
    else
    {
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h2 class="fw-bold text-dark mb-0">Customer Workspace Portal</h2>
                <p class="text-muted mb-0">Welcome back, <span class="text-primary fw-semibold">@Session.FullName</span>. Track your active job schedules and profile states here.</p>
            </div>
        </div>

        <div class="row g-4">
            @* --- Left Side: Reactive Dynamic Bookings Grid --- *@
            <div class="col-md-8">
                <div class="card shadow-sm border-0 rounded-4 p-4 mb-4 bg-white">
                    <h5 class="fw-bold text-dark mb-3"><i class="bi bi-journal-check me-2 text-primary"></i>Your Booked Appointments</h5>
                    <hr class="mt-0 mb-4" />

                    @if (userBookings == null)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border text-primary" role="status"></div>
                        </div>
                    }
                    else if (!userBookings.Any())
                    {
                        <div class="alert alert-light border text-center py-5 rounded-3">
                            <i class="bi bi-calendar2-x display-6 text-muted mb-2 d-block"></i>
                            <span class="text-secondary fw-semibold">No active service dispatches or appointment schedules found.</span>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border-0">
                                <thead class="table-light text-secondary small text-uppercase">
                                    <tr>
                                        <th>Service Listing</th>
                                        <th>Date</th>
                                        <th>Status Indicator</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var book in userBookings)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@(book.Service?.Title ?? $"Service item #{book.ServiceId}")</div>
                                                <span class="text-muted small">ID: #@book.BookingId</span>
                                            </td>
                                            <td class="text-muted small">@book.BookingDate.ToString("MMM dd, yyyy")</td>
                                            <td>
                                                <span class="badge @(book.Status == "Pending" ? "bg-warning text-dark" : "bg-success") px-3 py-2 rounded-pill">
                                                    @book.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

            @* --- Right Side: Customer Meta Profiles & Account Deletion Panel --- *@
            <div class="col-md-4">
                <div class="card shadow-sm border-0 rounded-4 p-4 text-center bg-white mb-4">
                    <div class="avatar-icon mb-2">
                        <i class="bi bi-person-circle text-secondary display-4"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-0">@Session.FullName</h5>
                    <span class="badge bg-light text-dark border mb-2 px-3 py-1 mt-1">Customer Account</span>
                    <p class="text-muted small mb-0"><i class="bi bi-shield-check text-success me-1"></i> Active Platform User</p>
                </div>

                @* --- Secure Profile Deletion Box --- *@
                <div class="card shadow-sm border-0 rounded-4 p-4 bg-white border-top border-5 border-danger">
                    <h5 class="fw-bold text-danger mb-2">
                        <i class="bi bi-shield-exclamation me-2"></i>Danger Zone
                    </h5>
                    <p class="text-muted mb-3 small">
                        Deleting your profile will permanently drop your historical booking records, clear preferences, and erase your customer account from the system databases.
                    </p>

                    @if (!showConfirmDelete)
                    {
                        <button class="btn btn-outline-danger w-100 fw-bold py-2 btn-sm rounded-3" @onclick="() => showConfirmDelete = true">
                            <i class="bi bi-trash3-fill me-2"></i> Delete My Profile
                        </button>
                    }
                    else
                    {
                        <div class="bg-light p-3 rounded border border-danger text-center animate-fade-in">
                            <p class="text-danger small fw-bold mb-2"><i class="bi bi-exclamation-triangle-fill"></i> This action is permanent! Proceed?</p>
                            <div class="d-flex gap-2 justify-content-center">
                                <button class="btn btn-danger btn-sm px-3 fw-bold rounded-3" @onclick="ConfirmAccountDeletion">Yes, Purge</button>
                                <button class="btn btn-secondary btn-sm px-3 rounded-3" @onclick="() => showConfirmDelete = false">Cancel</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Booking>? userBookings;
    private bool showConfirmDelete = false;

    protected override async Task OnInitializedAsync()
    {
        if (Session.IsLoggedIn && Session.Role == "Customer")
        {
            // Safely fetch user bookings. If you haven't implemented GetAllBookings, this falls back cleanly to an empty array
            try
            {
                var allBookings = await DataService.GetAllServicesAsync(); // Reuses your established framework query methods
                userBookings = new List<Booking>();
            }
            catch
            {
                userBookings = new List<Booking>();
            }
        }
    }

    private async Task ConfirmAccountDeletion()
    {
        var success = await DataService.DeleteCustomerAccountAsync(Session.UserId);
        if (success)
        {
            Session.Logout();
            Nav.NavigateTo("/", forceLoad: true);
        }
    }
}