@page "/"
@inject NavigationManager Nav
@inject LocalServicesPlatform.Services.UserSession Session
@rendermode InteractiveServer

<div class="welcome-container d-flex align-items-center justify-content-center">
    <div class="text-center p-5 card shadow-lg welcome-card border-0 rounded-4">
        <div class="brand-icon mb-4">
            <i class="bi bi-rocket-takeoff-fill text-primary display-1"></i>
        </div>
        <h1 class="display-4 fw-black text-dark mb-2">LocalServices</h1>
        <p class="text-muted fs-5 mb-5 mx-auto" style="max-width: 480px;">
            Your neighborhood marketplace for expert handymen, elite technicians, and instant local solutions.
        </p>

        <div class="d-grid gap-3 max-width-actions mx-auto">
            @if (Session.IsLoggedIn)
            {
                <button class="btn btn-primary btn-lg py-3 fw-bold shadow" @onclick="GoToPortal">
                    Enter App Portal <i class="bi bi-arrow-right ms-2"></i>
                </button>
            }
            else
            {
                @* Changed from @onclick to a direct clean href link so it works 100% of the time *@
                <a href="join" class="btn btn-primary btn-lg py-3 fw-bold shadow">
                    Get Started <i class="bi bi-shield-lock-fill ms-2"></i>
                </a>
            }
        </div>

        <div class="mt-5 text-muted small border-top pt-3">
            v2.0 Platform • Secure Connection Enforced
        </div>
    </div>
</div>

@code {
    private void GoToPortal()
    {
        if (Session.Role == "Provider")
        {
            Nav.NavigateTo("/provider-dashboard");
        }
        else
        {
            Nav.NavigateTo("/explore");
        }
    }
}

<style>
    .welcome-container {
        min-height: 85vh;
        background: radial-gradient(circle at 50% 50%, #f8f9fa 0%, #e9ecef 100%);
    }

    .welcome-card {
        background: #ffffff;
        max-width: 600px;
        width: 100%;
    }

    .fw-black {
        font-weight: 900;
    }

    .max-width-actions {
        max-width: 320px;
    }
</style>